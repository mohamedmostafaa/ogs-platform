# =============================================================================
# OGS Platform — canonical env var list.
#
# Copy to .env.local and fill in. NEVER commit .env.local — .gitignore blocks it.
# Every variable named in turbo.json#tasks.build.env must appear here.
# See blueprint §28.1.
# =============================================================================

NODE_ENV=development

# ----- Neon Postgres (pooled + direct) ---------------------------------------
DATABASE_URL=
DIRECT_URL=

# ----- Better Auth -----------------------------------------------------------
BETTER_AUTH_SECRET=                                # 32+ random bytes hex; openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000              # https://id.ogs-tc.com in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000          # per-app; override in each app's env
NEXT_PUBLIC_ID_URL=http://localhost:3000
OGS_ID_URL=http://localhost:3000

# OIDC clients (per-app — register at the identity hub once it's up)
OGS_OIDC_CLIENT_ID=
OGS_OIDC_CLIENT_SECRET=

# Social providers (configured at the identity hub only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ----- Encryption (AES-256-GCM with key-id rotation; see blueprint §15) ------
ENCRYPTION_KEY_ACTIVE_ID=k1
ENCRYPTION_KEYS={"k1":"<base64 32-byte key — openssl rand -base64 32>"}

# ----- SMTP (Nodemailer 8 — only email path; no vendor SDKs) -----------------
SMTP_HOST=sandbox.smtp.mailtrap.io                 # dev default
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=OGS Dev <dev@ogs-tc.local>
OGS_SUPPORT_FROM=noreply@ogs-tc.com

# ----- SMS + WhatsApp --------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+12025550199
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=

# ----- Inngest (background jobs) ---------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1                                      # local-only; do NOT set in prod
INNGEST_BASE_URL=

# ----- Stream.io (live video + chat) -----------------------------------------
STREAM_KEY=
STREAM_SECRET=
NEXT_PUBLIC_STREAM_KEY=                            # same as STREAM_KEY
STREAM_WEBHOOK_SECRET=

# ----- Bunny.net Stream (VOD; NOT Mux) ---------------------------------------
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_TOKEN_KEY=
BUNNY_WEBHOOK_SECRET=

# ----- Cloudflare R2 (S3-compatible files) -----------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ogs-platform
R2_PUBLIC_CDN=https://cdn.ogs-tc.com

# ----- Payments (admin-switchable; see blueprint §19) ------------------------
PAYMENT_DEFAULT_PROVIDER=STRIPE                    # STRIPE | LEMON | POLAR | PAYMOB

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Lemon Squeezy
LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_VARIANT_DEFAULT=
LEMON_WEBHOOK_SECRET=

# Polar
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox                               # production | sandbox
POLAR_WEBHOOK_SECRET=

# PayMob (Egypt)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

# ----- AI providers ----------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=                                    # optional; OpenAI fallback when missing
GOOGLE_API_KEY=                                    # optional Gemini

# ----- Arcjet (security middleware on every proxy.ts) ------------------------
ARCJET_KEY=

# ----- Observability (Sentry) ------------------------------------------------
SENTRY_DSN=
SENTRY_ORG=ogs-platform
SENTRY_PROJECT=                                    # one per app; override per app
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# ----- Webhooks IP allow-list (PayMob, Tap; comma-separated CIDRs) ----------
WEBHOOK_IP_ALLOWLIST=

# ----- Vercel-provided (do not set manually) ---------------------------------
# VERCEL_URL
