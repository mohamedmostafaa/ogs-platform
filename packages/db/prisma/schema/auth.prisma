// ---------------------------------------------------------------------------
// auth.prisma — Better Auth + OAuth provider tables.
//
// Mirrors the canonical Better Auth 1.6 schema (User, Account, Session,
// Verification) plus tables the @better-auth/oauth-provider plugin
// requires (OAuthApplication, OAuthAccessToken, OAuthConsent).
//
// Better Auth manages writes to these tables — application code reads
// only via @ogs/auth helpers.
//
// @see Blueprint §5.5, §6.4.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  /// E.164 phone number; null until OTP-verified.
  phone         String?   @unique
  phoneVerified Boolean   @default(false)
  /// Preferred locale; one of @ogs/config LOCALES.
  locale        String    @default("en")
  /// Hashed password — null when user signs in via OAuth only.
  passwordHash     String?
  /// True once the user has completed TOTP enrolment via the Better Auth
  /// twoFactor plugin. Sessions issued before 2FA verification carry
  /// `session.twoFactorVerified === false` — guards enforce that gate.
  twoFactorEnabled Boolean   @default(false)
  /// Soft-delete sentinel.
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts                Account[]
  sessions                Session[]
  memberships             Membership[]
  consents                OAuthConsent[]
  accessTokens            OAuthAccessToken[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  preferences             UserPreference?
  twoFactor               TwoFactor[]

  @@index([deletedAt])
}

/// Per-user TOTP secret + recovery codes for the Better Auth `twoFactor`
/// plugin. Better Auth manages writes; application code reads via
/// `auth.api.*` only — never query this table directly.
///
/// `secret` is encrypted at rest by Better Auth's standard envelope
/// (derived from `BETTER_AUTH_SECRET`); `backupCodes` is a
/// JSON-encoded array of *hashed* one-time recovery codes.
model TwoFactor {
  id          String  @id @default(cuid())
  secret      String
  backupCodes String
  /// `false` until the user verifies the first TOTP code, then `true`.
  ///
  /// NOTE: Better Auth's declared schema (`two-factor/schema.d.mts`)
  /// uses `defaultValue: true`. We diverge intentionally and default
  /// to `false` — fail-closed. BA always writes this column on insert
  /// via its adapter, so the column-default value is only exercised on
  /// a hypothetical direct-DB insert path. Defaulting to `false` there
  /// means a malformed row blocks the user from completing 2FA rather
  /// than auto-promoting them as verified. Reviewed in Chunk-A of
  /// Phase 02; deliberate.
  verified    Boolean @default(false)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("twoFactor")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  /// OAuth refresh token (encrypted at rest by the encryption envelope).
  refreshToken          String?
  /// OAuth access token (encrypted at rest).
  accessToken           String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  /// Hashed password — Better Auth's credential-provider table.
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(cuid())
  /// Identifier — email, phone, or OAuth state token.
  identifier String
  /// One-time value; for OTP this is the 6-digit code hashed.
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

// ---- @better-auth/oauth-provider tables -----------------------------------

model OAuthApplication {
  id           String   @id @default(cuid())
  clientId     String   @unique
  /// Hashed client secret.
  clientSecret String
  name         String
  redirectUris String[] @default([])
  scopes       String[] @default([])
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OAuthAccessToken {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  /// Hashed access token (lookup happens on the hash, never the plaintext).
  tokenHash String   @unique
  scopes    String[] @default([])
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
}

model OAuthConsent {
  id        String    @id @default(cuid())
  userId    String
  clientId  String
  scopes    String[]  @default([])
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  /// JSON blob for per-user UI prefs (theme, density, etc.).
  prefs     Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
