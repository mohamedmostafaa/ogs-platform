// ---------------------------------------------------------------------------
// notifications.prisma — Document, Notification, NotificationPreference.
//
// `Document` is the generic file table — CVs, profile photos, course
// material uploads. `Notification` is the in-app notification feed;
// each row may also be fanned out to email / SMS / WhatsApp depending
// on the user's NotificationPreference.
//
// @see Blueprint §5.15.
// ---------------------------------------------------------------------------

model Document {
  id         String    @id @default(cuid())
  tenantId   String
  /// Owner (User.id or Company.id).
  ownerType  String
  ownerId    String
  /// "cv" | "avatar" | "credential" | "course_material" | "other".
  category   String
  /// User-facing filename.
  filename   String
  /// R2 object key.
  storageKey String    @unique
  /// MIME type at upload time.
  mimeType   String
  /// Byte size.
  sizeBytes  Int
  /// SHA-256 hex of contents.
  sha256     String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, ownerType, ownerId])
  @@index([category])
}

model Notification {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  /// "application_status" | "interview_scheduled" | "course_assigned" | ...
  type              String
  /// Localised payload — `{ "en": {...}, "ar": {...} }`.
  payload           Json
  readAt            DateTime?
  /// Channels successfully delivered to (e.g. ["inapp","email"]).
  deliveredChannels String[]  @default([])
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, readAt, createdAt])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  /// Notification type key (same domain as Notification.type).
  type      String
  /// "inapp" | "email" | "sms" | "whatsapp".
  channel   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
}
