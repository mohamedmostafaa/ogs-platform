// ---------------------------------------------------------------------------
// secrets.prisma — SecretCredential (envelope-encrypted at rest).
//
// Stores high-sensitivity credentials that must NOT live in env vars:
//   - Per-tenant payment provider keys (Stripe restricted keys).
//   - Per-tenant ATS connector keys.
//   - User-uploaded API keys for AI providers (BYOK).
//
// The `ciphertext` column holds AES-256-GCM output; `keyVersion` tracks
// which ENCRYPTION_KEY_<n> was used (drives rotation). Plaintext is
// decrypted only inside the encryption helper, never logged.
//
// Type prefix `ARCJET_KEY-class` in blueprint §5.13 means
// "high-sensitivity site key" — these rows obey strict access via the
// audit + tenant-scope extensions.
//
// @see Blueprint §5.13, SECURITY.md §7 (envelope encryption).
// ---------------------------------------------------------------------------

model SecretCredential {
  id         String    @id @default(cuid())
  tenantId   String
  /// Free-form discriminator: "stripe_restricted", "byok_anthropic", etc.
  type       String
  /// Human label for the admin UI.
  name       String
  /// AES-256-GCM ciphertext, base64-encoded.
  ciphertext String
  /// 96-bit IV, base64-encoded (unique per encryption).
  iv         String
  /// 128-bit GCM tag, base64-encoded.
  authTag    String
  /// The key version that produced this ciphertext.
  keyVersion Int
  /// Optional metadata (last-4 digits, fingerprint, etc.).
  metadata   Json?
  expiresAt  DateTime?
  rotatedAt  DateTime?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, type, name])
  @@index([tenantId, type])
}
